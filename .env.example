# =============================================================================
# BBVA RAG Assistant - Configuración
# Copiar este archivo como .env y ajustar los valores según sea necesario
# =============================================================================

# --- Scraping ---
SELENIUM_REMOTE_URL=http://chrome:4444/wd/hub
SCRAPE_URL=https://www.bbva.com.co/
SCRAPE_MAX_PAGES=30

# --- Chunking ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# --- Embedding ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Vector Store (ChromaDB) ---
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=bbva_docs

# --- LLM ---
# Proveedores soportados: ollama, openai, groq
LLM_PROVIDER=ollama
LLM_BASE_URL=http://ollama:11434/v1
LLM_MODEL=llama3.2
LLM_API_KEY=ollama
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
SYSTEM_PROMPT=Eres un asistente virtual experto de BBVA Colombia.

# Para usar Groq (free tier):
# LLM_PROVIDER=groq
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-8b-instant
# LLM_API_KEY=gsk_TU_API_KEY_AQUI

# Para usar OpenAI:
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-3.5-turbo
# LLM_API_KEY=sk-TU_API_KEY_AQUI

# --- Reranker ---
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- RAG ---
RETRIEVE_K=10
RERANK_TOP_K=3
HISTORY_MESSAGES=10

# --- Almacenamiento ---
DATA_DIR=./data
DB_PATH=./data/conversations.db

# --- Logging ---
LOG_LEVEL=INFO

# --- API ---
API_URL=http://api:8000
