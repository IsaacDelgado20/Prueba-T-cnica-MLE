  <diagram id="factory-singleton-pattern" name="Factory + Singleton Pattern">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Factory Pattern + Singleton Pattern - ServiceContainer&lt;/b&gt;&lt;br&gt;&lt;i&gt;Centraliza la creación de objetos y garantiza una instancia única del contenedor&lt;/i&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="700" height="50" as="geometry" />
        </mxCell>

        <!-- ========= ServiceContainer (center) ========= -->
        <mxCell id="container" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;ServiceContainer&lt;/b&gt;&lt;br&gt;&lt;i&gt;Factory + Singleton&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;- _instance: ServiceContainer = None (class var)&lt;br&gt;- _settings: Settings&lt;br&gt;- _embedding: EmbeddingPort&lt;br&gt;- _vector_store: VectorStorePort&lt;br&gt;- _llm: LLMPort&lt;br&gt;- _reranker: RerankerPort&lt;br&gt;- _conversation_repo: ConversationRepository&lt;br&gt;- _document_repo: DocumentRepository&lt;br&gt;- _scraper: ScraperPort&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;+ &lt;b&gt;instance&lt;/b&gt;(settings): ServiceContainer  ← &lt;i&gt;Singleton&lt;/i&gt;&lt;br&gt;+ &lt;b&gt;get_llm&lt;/b&gt;(): LLMPort  ← &lt;i&gt;Factory Method&lt;/i&gt;&lt;br&gt;+ get_embedding(): EmbeddingPort&lt;br&gt;+ get_vector_store(): VectorStorePort&lt;br&gt;+ get_reranker(): RerankerPort&lt;br&gt;+ get_conversation_repo(): ConversationRepository&lt;br&gt;+ get_document_repo(): DocumentRepository&lt;br&gt;+ get_scraper(): ScraperPort&lt;br&gt;+ get_scraping_service(): ScrapingService&lt;br&gt;+ get_rag_service(): RAGService&lt;br&gt;+ get_analytics_service(): AnalyticsService&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=12;fontFamily=Helvetica;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;arcSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="80" width="430" height="370" as="geometry" />
        </mxCell>
        <mxCell id="container_file" value="📁 src/infrastructure/container.py" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="370" y="60" width="250" height="20" as="geometry" />
