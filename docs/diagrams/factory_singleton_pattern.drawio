        <!-- ========= Singleton Note ========= -->
        <mxCell id="singleton_note" value="&lt;b&gt;🔒 Singleton Pattern:&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;code&gt;_instance = None  # class var&lt;br&gt;&lt;br&gt;@classmethod&lt;br&gt;def instance(cls, settings):&lt;br&gt;    if cls._instance is None:&lt;br&gt;        cls._instance = cls(settings)&lt;br&gt;    return cls._instance&lt;/code&gt;&lt;br&gt;&lt;br&gt;Garantiza una sola instancia,&lt;br&gt;evitando duplicar modelos ML&lt;br&gt;y conexiones costosas." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="850" y="230" width="260" height="220" as="geometry" />
        </mxCell>

        <!-- Factory Decision Note -->
        <mxCell id="factory_note" value="&lt;b&gt;🏭 Factory Method (get_llm):&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;code&gt;if provider == &quot;ollama&quot;:&lt;br&gt;    return OllamaLLMAdapter(...)&lt;br&gt;elif provider in (&quot;openai&quot;, &quot;groq&quot;):&lt;br&gt;    return OpenAILLMAdapter(...)&lt;/code&gt;&lt;br&gt;&lt;br&gt;Selección de implementación&lt;br&gt;en runtime basada en config." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="50" y="380" width="250" height="170" as="geometry" />
        </mxCell>

