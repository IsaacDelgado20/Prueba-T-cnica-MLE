          <mxGeometry x="70" y="525" width="280" height="20" as="geometry" />
        </mxCell>

        <!-- SQLite icon -->
        <mxCell id="sqlite_icon" value="🗄️ SQLite" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="575" width="120" height="70" as="geometry" />
