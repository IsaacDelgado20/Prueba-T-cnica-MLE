        <mxCell id="arrow_fs2" style="endArrow=open;endSize=12;html=1;exitX=0.7;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="file_repo" target="clean_dir">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Entities -->
        <mxCell id="conv_entity" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;Conversation&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;+ id: str&lt;br&gt;+ messages: List[Message]&lt;br&gt;+ created_at: datetime&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="685" width="200" height="100" as="geometry" />
        </mxCell>

        <mxCell id="doc_entity" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;Document&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;+ id: str&lt;br&gt;+ url: str&lt;br&gt;+ raw_content: str&lt;br&gt;+ clean_content: str&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Helvetica;html=1;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="685" width="200" height="110" as="geometry" />
        </mxCell>

        <mxCell id="entity_label" value="📁 src/domain/entities.py" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="160" y="660" width="200" height="20" as="geometry" />
        </mxCell>

        <!-- Note -->
        <mxCell id="note1" value="&lt;b&gt;Repository Pattern:&lt;/b&gt;&lt;br&gt;El dominio define los contratos&lt;br&gt;(interfaces). La infraestructura&lt;br&gt;implementa el almacenamiento&lt;br&gt;concreto. Se puede cambiar&lt;br&gt;SQLite → PostgreSQL sin&lt;br&gt;afectar el dominio." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="490" y="685" width="230" height="120" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
