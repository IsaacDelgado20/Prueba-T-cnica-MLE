        <!-- Arrow to DB -->
        <mxCell id="arrow_db" style="endArrow=open;endSize=12;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="sqlite_repo" target="sqlite_icon">
          <mxGeometry relative="1" as="geometry" />
