  <diagram id="repository-pattern" name="Repository Pattern">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Repository Pattern - Persistencia de Datos&lt;/b&gt;&lt;br&gt;&lt;i&gt;Abstrae el mecanismo de almacenamiento, desacoplando el dominio de la infraestructura&lt;/i&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="234" y="15" width="700" height="50" as="geometry" />
        </mxCell>

        <!-- ========= CONVERSATION REPOSITORY (LEFT) ========= -->
        <mxCell id="conv_header" value="&lt;b&gt;Repositorio de Conversaciones&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="100" y="75" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- ConversationRepository Interface -->
        <mxCell id="conv_repo_iface" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;i&gt;&amp;lt;&amp;lt;interface&amp;gt;&amp;gt;&lt;/i&gt;&lt;br&gt;&lt;b&gt;ConversationRepository&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;+ save(conversation: Conversation): None&lt;br&gt;+ get(conversation_id: str): Optional[Conversation]&lt;br&gt;+ list_all(): List[Conversation]&lt;br&gt;+ delete(conversation_id: str): None&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=12;fontFamily=Helvetica;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="115" width="400" height="140" as="geometry" />
        </mxCell>
        <mxCell id="conv_file1" value="📁 src/domain/ports.py" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="50" y="95" width="200" height="20" as="geometry" />
        </mxCell>

        <!-- SQLiteConversationRepository -->
        <mxCell id="sqlite_repo" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;SQLiteConversationRepository&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;- _db_path: str&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;+ save(conversation): None&lt;br&gt;+ get(conversation_id): Optional[Conversation]&lt;br&gt;+ list_all(): List[Conversation]&lt;br&gt;+ delete(conversation_id): None&lt;br&gt;- _init_db(): None&lt;br&gt;- _connect(): Connection&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=12;fontFamily=Helvetica;html=1;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;arcSize=10;" vertex="1" parent="1">
