        <!-- Arrow to filesystem -->
        <mxCell id="arrow_fs1" style="endArrow=open;endSize=12;html=1;exitX=0.3;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="file_repo" target="raw_dir">
