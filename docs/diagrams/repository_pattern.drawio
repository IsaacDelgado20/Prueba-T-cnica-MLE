        <mxCell id="doc_file1" value="📁 src/domain/ports.py" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="600" y="95" width="200" height="20" as="geometry" />
        </mxCell>

        <!-- FileDocumentRepository -->
        <mxCell id="file_repo" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;FileDocumentRepository&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;- _raw_dir: str&lt;br&gt;- _clean_dir: str&lt;/p&gt;&lt;hr size=&quot;1&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;+ save_raw(document): None&lt;br&gt;+ save_clean(document): None&lt;br&gt;+ list_documents(): List[Dict]&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=12;fontFamily=Helvetica;html=1;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="625" y="340" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="doc_file2" value="📁 src/infrastructure/document_repo.py" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="625" y="505" width="280" height="20" as="geometry" />
        </mxCell>

        <!-- Filesystem icons -->
        <mxCell id="raw_dir" value="📁 data/raw/&lt;br&gt;(.html + .json)" style="shape=folder;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;tabWidth=80;tabHeight=20;" vertex="1" parent="1">
          <mxGeometry x="580" y="575" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="clean_dir" value="📁 data/clean/&lt;br&gt;(.txt + .json)" style="shape=folder;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;tabWidth=80;tabHeight=20;" vertex="1" parent="1">
          <mxGeometry x="760" y="575" width="140" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow implements doc -->
        <mxCell id="arrow_doc" style="endArrow=block;endSize=16;endFill=0;dashed=1;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="file_repo" target="doc_repo_iface">
